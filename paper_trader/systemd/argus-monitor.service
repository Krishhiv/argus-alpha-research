[Unit]
Description=Argus paper-trader monitor dashboard (always-on, localhost:8082)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/paper-trader
ExecStart=/home/ubuntu/paper-trader/venv/bin/python -m paper_trader.monitor.serve_monitor --port 8082
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
